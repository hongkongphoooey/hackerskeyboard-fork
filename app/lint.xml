<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!--
        UnusedResources: Many resources (drawables, bools, dimens) are accessed
        dynamically at runtime via getIdentifier() for plugin dictionary support and
        theme switching. Static analysis cannot trace these references. Suppressed
        project-wide to avoid false positives from legitimate dynamic access.
    -->
    <issue id="UnusedResources" severity="ignore" />

    <!--
        Overdraw: All keyboard input view layouts intentionally draw their own
        backgrounds for theming (dark/light/transparent/material variants). The
        system window background behind an IME is unavoidable and these backgrounds
        are required for correct visual appearance of each keyboard theme.
    -->
    <issue id="Overdraw" severity="ignore" />

    <!--
        WrongRegion: The locale folders de-rNE, es-rLA, and ru-rPH are intentional.
        - de-rNE: German keyboard layout variant for Niger (used by some communities)
        - es-rLA: Spanish keyboard layout variant for Latin America (LA is used as a
          regional code even though it is not an official ISO 3166-1 country code)
        - ru-rPH: Russian keyboard layout variant for Philippines (Russian-speaking
          communities in the Philippines)
        These are deliberate keyboard layout resource qualifiers, not mistakes.
    -->
    <issue id="WrongRegion" severity="ignore" />

    <!--
        DiscouragedApi (getIdentifier): Used in LatinIME and PluginManager to load
        dictionary resources from third-party plugin APKs whose resource IDs are
        unknown at compile time. There is no compile-time alternative for resources
        in external packages — getIdentifier() is the only correct approach here.
    -->
    <issue id="DiscouragedApi" severity="ignore" />

    <!--
        Icon issues: IconDensities, IconDuplicates, IconDuplicatesConfig, IconDipSize.
        These require changes to binary image assets (creating missing density
        variants or deduplicating .png files). Left for a separate asset-management
        pass; they do not affect runtime correctness.
    -->
    <issue id="IconDensities" severity="ignore" />
    <issue id="IconDuplicates" severity="ignore" />
    <issue id="IconDuplicatesConfig" severity="ignore" />
    <issue id="IconDipSize" severity="ignore" />

</lint>
